    <script>
        let allGames = [];
        const homeView = document.getElementById('home-view');
        const detailView = document.getElementById('detail-view');
        const statusIndicator = document.getElementById('status-indicator');

        async function bootSystem() {
            // ... (keep your existing bootSystem code)
        }

        async function initData() {
            try {
                const gamesRes = await fetch('./data/games.json');
                allGames = await gamesRes.json();
                statusIndicator.style.display = 'none';
                renderGames(allGames);
            } catch (error) {
                console.error("Data Engine Error:", error);
                // For demo if local fetch fails:
                allGames = [{id: 1, title: "Steal a Brainrot", slug: "steal-brainrot", description: "The ultimate heist.", image: "https://via.placeholder.com/300x150"}];
                renderGames(allGames);
            }
        }

        // PLACE 2: IMAGE ADDED TO DYNAMIC GAME CARDS
        function renderGames(data) {
            const grid = document.getElementById('game-grid');
            if (!data || data.length === 0) return;
            grid.innerHTML = data.map(game => `
                <div class="game-card" role="button" tabindex="0" onclick="location.hash='game/${game.slug || game.id}'">
                    <img src="${game.image || 'https://via.placeholder.com/220x140?text=No+Preview'}" alt="${game.title}">
                    <div class="game-card-content">
                        <h3 style="margin: 0 0 5px 0;">${game.title}</h3>
                        <p style="font-size: 0.85rem; color: #888; margin: 0;">${game.description || 'No description.'}</p>
                    </div>
                </div>
            `).join('');
        }

        // ... (keep the rest of your listeners)
        document.getElementById('mainSearch').addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            const filteredGames = allGames.filter(g => (g.title && g.title.toLowerCase().includes(query)));
            renderGames(filteredGames);
        });

        window.addEventListener('hashchange', () => {
            const hash = location.hash;
            if(!hash || !hash.startsWith('#game/')) { 
                homeView.style.display = 'block';
                detailView.style.display = 'none';
                return; 
            }
            const slug = hash.replace('#game/', '');
            homeView.style.display = 'none';
            detailView.style.display = 'block';
            document.getElementById('game-title-display').innerText = `> Initializing: ${slug.toUpperCase()}`;
        });

        window.addEventListener('DOMContentLoaded', () => {
            bootSystem();
            initData();
            if(location.hash) window.dispatchEvent(new Event('hashchange'));
        });
    </script>
